{
  "name": "deleteclaw",
  "version": "1.0.0",
  "description": "One-click uninstaller for OpenClaw (Windows, macOS, Linux)",
  "main": "index.js",
  "type": "module",
  "bin": {
    "deleteclaw": "./index.js"
  },
  "scripts": {
    "test": "node index.js --dry-run",
    "build": "pkg . --targets node20-win-x64,node20-macos-x64,node20-linux-x64 --out-path dist"
  },
  "keywords": [
    "openclaw",
    "uninstaller",
    "cleaner"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
